        {
          "name": "Test Post Pet",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();",
                  "const rawBody = pm.response.text();",
                  "",
                  "// Extract id as string to avoid JS float precision loss",
                  "const match = rawBody.match(/\"id\"\\s*:\\s*(\\d+)/);",
                  "const petId = match ? match[1] : String(jsonData.id);",
                  "",
                  "if (petId) {",
                  "    console.log(petId);",
